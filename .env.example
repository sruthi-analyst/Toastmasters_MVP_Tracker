# Copy this file to .env and fill in real values before deploying.

# First-run admin password (only used the very first time the app starts,
# to create the initial account). Change it immediately after first login
# using the "Change password" option in the dashboard - after that, this
# value in .env is ignored.
ADMIN_PASSWORD=changeme123

# Long random string used to sign login session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-this-with-a-long-random-string

# Optional viewer-only password for read-only access.
# If not set, the default viewer password is viewonly123
VIEWER_PASSWORD=viewonly123

# Port the server listens on (most hosts set this automatically - leave as is)
PORT=3000
